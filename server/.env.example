# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Browser origin allowed for credentialed CORS (Vite client)
CLIENT_ORIGIN=http://localhost:5173

# Database (optional for local scaffold — leave empty to skip connection)
# Example: postgresql://USER:PASSWORD@localhost:5432/parkar
DATABASE_URL=

# Development only: fixed 6-digit OTP for local/tests (ignored in production)
# DEV_OTP_FIXED=000000
